{
  "name": "backend",
  "version": "1.0.0",
  "description": "[![License](https://img.shields.io/badge/license-MIT-blue.svg)](https://opensource.org/licenses/MIT)",
  "main": "dist/src/start.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "scripts": {
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "vercel-build": "prisma generate --config prisma.config.ts",
    "postinstall": "prisma generate --config prisma.config.ts",
    "start": "node dist/src/start.js",
    "dev": "ts-node-dev --respawn --transpile-only src/start.ts",
    "test": "jest",
    "test:watch": "jest --watch --verbose",
    "create-domain": "zx scripts/dev/domain-generator.ts",
    "lint": "eslint \"src/**/*.{ts,js}\" \"test/**/*.{ts,js}\" \"scripts/**/*.{ts,js}\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier \"src/**/*.{ts,js,json}\" \"test/**/*.{ts,js,json}\" \"scripts/**/*.{ts,js,json}\" --write",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
    "prisma:deploy": "prisma migrate deploy --config prisma.config.ts",
    "prisma:studio": "prisma studio --config prisma.config.ts",
    "seed:users": "ts-node scripts/seed-users.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.1",
    "@vercel/node": "^5.8.19",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cron": "^3.1.6",
    "cron-validator": "^1.4.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.11",
    "nodemon": "^3.1.0",
    "pg": "^8.16.3",
    "prisma": "^7.0.1",
    "ulid": "^2.3.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/cron": "^2.4.3",
    "@types/express": "^5.0.5",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "zx": "^8.0.1"
  }
}
